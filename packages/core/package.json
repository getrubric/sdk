{
  "name": "@rubric-app/core",
  "version": "0.2.1",
  "description": "Framework-neutral runtime building blocks for Rubric SDK adapters — agent identity, policy bundle polling, audit sink, and tool-call evaluator.",
  "license": "MIT",
  "homepage": "https://rubric-app.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getrubric/sdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/getrubric/sdk/issues"
  },
  "keywords": [
    "rubric",
    "ai-agents",
    "agent-governance",
    "policy-engine",
    "policy-evaluator",
    "audit",
    "security",
    "guardrails"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && NODE_ENV=test RUBRIC_INTERNAL_ALLOW_LOOPBACK_FOR_TESTS=1 node --test test/*.test.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "re2": "^1.24.1",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
