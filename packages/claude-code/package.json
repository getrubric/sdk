{
  "name": "@rubric-app/claude-code",
  "version": "0.1.2",
  "description": "Rubric Claude Code adapter — long-lived loopback daemon + `rubric` CLI that routes every Claude Code tool call through the Rubric policy engine and audit log.",
  "license": "MIT",
  "homepage": "https://rubric-app.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getrubric/sdk.git",
    "directory": "packages/claude-code"
  },
  "bugs": {
    "url": "https://github.com/getrubric/sdk/issues"
  },
  "keywords": [
    "rubric",
    "claude-code",
    "anthropic",
    "ai-agents",
    "agent-governance",
    "policy",
    "audit",
    "security",
    "hooks",
    "guardrails"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rubric": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && RUBRIC_INTERNAL_ALLOW_LOOPBACK_FOR_TESTS=1 node --test test/*.test.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@rubric-app/core": "workspace:*",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
